{
  "name": "@headers/sncb",
  "version": "0.4.0",
  "description": "CLI for the Seneca REST API (manage websites, pages, folders, and agent configuration).",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "engines": {
    "bun": ">=1.3"
  },
  "bin": {
    "sncb": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --target=bun --outdir=dist --minify && chmod +x dist/cli.js",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "coverage": "bun test --coverage",
    "lint": "bunx eslint .",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bun": "^1.3.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.18.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.21.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headers-cz/sncb.git"
  },
  "homepage": "https://github.com/headers-cz/sncb#readme",
  "bugs": {
    "url": "https://github.com/headers-cz/sncb/issues"
  },
  "keywords": [
    "seneca",
    "headers",
    "cli",
    "chatbot",
    "help-center",
    "rest-api",
    "bun"
  ]
}
